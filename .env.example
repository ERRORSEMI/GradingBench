# Copy to .env and export, or: source scripts/env.sh

# PIGAI_REPO_ROOT=/path/to/repo
# PIGAI_DATA_ROOT=${PIGAI_REPO_ROOT}/data
# PIGAI_RESULTS_ROOT=${PIGAI_REPO_ROOT}/results

# GradingBench on Hugging Face
# HF_DATASET_REPO=ERRORSEMI/GradingBench
# HF_ENDPOINT=https://huggingface.co

# Stage2 text filter model
PIGAI_FILTER_MODEL_PATH=/path/to/Qwen3-8B

# Open-source model weights directory (run_vllm.sh uses ${MODEL_ROOT}/vendor/model-name)
MODEL_ROOT=/path/to/models

# Hosted VL API (optional, for main_modelpigai_api.py)
# OpenAI-compatible chat/completions endpoint; auth header: Bearer {APP_ID}:{APP_KEY}
PIGAI_API_APP_ID=
PIGAI_API_APP_KEY=
PIGAI_API_ENDPOINT=https://your-api-endpoint/v1/chat/completions

# Optional per-model credentials
# PIGAI_API_APP_ID_DOUBAO=
# PIGAI_API_APP_KEY_DOUBAO=
# PIGAI_API_APP_ID_QWEN3=
# PIGAI_API_APP_KEY_QWEN3=

# GPU
# CUDA_VISIBLE_DEVICES=0,1
# TENSOR_PARALLEL_SIZE=2
